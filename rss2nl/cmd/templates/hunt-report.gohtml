<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <style>
    :root {
      --bg: #f7f8fa;
      --surface: #ffffff;
      --border: #d8dee7;
      --hairline: #e7ebf0;
      --text: #17202a;
      --muted: #5f6f82;
      --subtle: #eef2f6;
      --link: #0f62fe;
      --warning-bg: #fff8df;
      --warning-border: #e8b923;
      --failure-bg: #fff0f0;
      --failure-border: #e25555;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0d1117;
        --surface: #161b22;
        --border: #30363d;
        --hairline: #21262d;
        --text: #c9d1d9;
        --muted: #8b949e;
        --subtle: #21262d;
        --link: #58a6ff;
        --warning-bg: #29240e;
        --warning-border: #9e8a26;
        --failure-bg: #2d1215;
        --failure-border: #da3633;
      }
    }

    [data-theme="dark"] {
      --bg: #0d1117;
      --surface: #161b22;
      --border: #30363d;
      --hairline: #21262d;
      --text: #c9d1d9;
      --muted: #8b949e;
      --subtle: #21262d;
      --link: #58a6ff;
      --warning-bg: #29240e;
      --warning-border: #9e8a26;
      --failure-bg: #2d1215;
      --failure-border: #da3633;
    }

    [data-theme="light"] {
      --bg: #f7f8fa;
      --surface: #ffffff;
      --border: #d8dee7;
      --hairline: #e7ebf0;
      --text: #17202a;
      --muted: #5f6f82;
      --subtle: #eef2f6;
      --link: #0f62fe;
      --warning-bg: #fff8df;
      --warning-border: #e8b923;
      --failure-bg: #fff0f0;
      --failure-border: #e25555;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
    }

    main {
      width: min(1120px, calc(100% - 32px));
      margin: 0 auto;
      padding: 32px 0 48px;
    }

    a { color: var(--link); overflow-wrap: anywhere; }
    h1, h2, h3, p { margin-top: 0; }
    h1 { font-size: 28px; line-height: 1.15; margin-bottom: 8px; }
    h2 { font-size: 20px; line-height: 1.2; margin-bottom: 0; }
    h3 { font-size: 16px; line-height: 1.25; margin-bottom: 6px; }
    ol, ul { padding-left: 20px; }

    .page-header { margin-bottom: 24px; }
    .muted { color: var(--muted); font-size: 13px; }

    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
      margin: 16px 0 20px;
    }

    .stat {
      min-width: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
    }

    .stat-value { display: block; font-size: 22px; font-weight: 700; line-height: 1.15; }
    .stat-label { display: block; color: var(--muted); font-size: 12px; margin-top: 4px; }

    .category-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 4px 0 24px;
    }

    .category-nav a {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text);
      font-size: 13px;
      padding: 5px 10px;
      text-decoration: none;
    }

    .notice {
      border-radius: 8px;
      margin: 8px 0;
      padding: 10px 12px;
      overflow-wrap: anywhere;
    }

    .warning { background: var(--warning-bg); border: 1px solid var(--warning-border); }
    .failure { background: var(--failure-bg); border: 1px solid var(--failure-border); }

    .category-section { margin-top: 30px; }

    .category-heading {
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: space-between;
      margin-bottom: 12px;
      padding-bottom: 8px;
    }

    .candidate-list {
      display: grid;
      gap: 8px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .candidate {
      min-width: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
    }

    .candidate-header {
      align-items: flex-start;
      display: flex;
      gap: 10px;
      justify-content: space-between;
      min-width: 0;
    }

    .candidate-title {
      font-size: 15px;
      font-weight: 650;
      line-height: 1.25;
      min-width: 0;
    }

    .candidate-url {
      color: var(--muted);
      display: block;
      font-size: 11px;
      line-height: 1.25;
      margin-top: 2px;
      text-decoration: none;
    }

    .status {
      background: var(--subtle);
      border-radius: 999px;
      color: var(--muted);
      flex: 0 0 auto;
      font-size: 12px;
      padding: 2px 8px;
      white-space: nowrap;
    }

    .candidate-body {
      display: grid;
      gap: 10px;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 30%);
      margin-top: 8px;
      min-width: 0;
    }

    .candidate-main, .candidate-side { min-width: 0; }

    .reason {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
      margin: 0;
      overflow-wrap: anywhere;
      white-space: pre-wrap;
    }

    .candidate-side {
      border-left: 1px solid var(--hairline);
      display: grid;
      gap: 6px;
      padding-left: 10px;
    }

    .evidence { min-width: 0; }

    .evidence-title {
      color: var(--muted);
      font-size: 11px;
      font-weight: 650;
      line-height: 1.25;
      margin-bottom: 3px;
    }

    .evidence-list {
      display: grid;
      gap: 2px;
      list-style: none;
      margin: 0;
      padding: 0;
      font-size: 11px;
      line-height: 1.3;
    }

    .candidate-meta {
      border-top: 1px solid var(--hairline);
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding-top: 6px;
      font-size: 11px;
      line-height: 1.25;
    }

    .candidate-meta span::after { content: "|"; margin-left: 6px; }
    .candidate-meta span:last-child::after { content: ""; margin-left: 0; }

    .theme-toggle {
      position: fixed;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
      z-index: 100;
    }
    .theme-toggle:hover { background: var(--subtle); }

    @media (max-width: 760px) {
      main { width: min(100% - 20px, 1120px); padding-top: 20px; }
      h1 { font-size: 24px; }
      .candidate-header { display: block; }
      .candidate-body { display: block; }
      .candidate-side {
        border-left: 0;
        border-top: 1px solid var(--hairline);
        margin-top: 8px;
        padding-left: 0;
        padding-top: 6px;
      }
      .status { display: inline-block; margin-top: 8px; }
    }
  </style>
</head>
<body>
  <main>
    <header class="page-header">
      <h1>{{.Title}}</h1>
      <p class="muted">Generated: {{.GeneratedAt}}. Mode: {{.Mode}}.</p>
    </header>

    <section class="summary" aria-label="Run summary">
      {{range .Stats}}
      <div class="stat"><span class="stat-value">{{.Value}}</span><span class="stat-label">{{.Label}}</span></div>
      {{end}}
    </section>

    {{if .HasWarnings}}
    <section aria-label="Warnings">
      <h2>Warnings</h2>
      {{range .Warnings}}<div class="notice warning">{{.Message}}</div>
      {{end}}
    </section>
    {{end}}

    {{if .HasFailures}}
    <section aria-label="Provider failures">
      <h2>Provider Failures</h2>
      {{range .Failures}}<div class="notice failure">{{.Message}}</div>
      {{end}}
    </section>
    {{end}}

    {{if .HasNoCandidates}}
    <section><h2>Candidates</h2><p class="muted">No candidates accepted. Check warnings, failures, or filters.</p></section>
    {{else}}
    {{if .HasMultipleCategories}}
    <nav class="category-nav" aria-label="Categories">
      {{range .Categories}}<a href="#{{.ID}}">{{.Name}} ({{.Count}})</a>
      {{end}}
    </nav>
    {{end}}

    {{range .Categories}}
    <section class="category-section" id="{{.ID}}">
      <div class="category-heading"><h2>{{.Name}}</h2><span class="muted">{{.Count}} candidates</span></div>
      <ol class="candidate-list">
        {{range .Candidates}}
        <li class="candidate">
          <div class="candidate-header">
            <div>
              <a class="candidate-title" href="{{.URL}}" target="_blank" rel="noreferrer">{{.Title}}</a>
              <a class="candidate-url" href="{{.URL}}" target="_blank" rel="noreferrer">{{.URL}}</a>
            </div>
            <span class="status">{{.Status}}</span>
          </div>
          <div class="candidate-body">
            <div class="candidate-main"><p class="reason">{{.Reason}}</p></div>
            <div class="candidate-side">
              {{if .HasEvidence}}
              <div class="evidence">
                <div class="evidence-title">Evidence</div>
                <ul class="evidence-list">
                  {{range .EvidenceURLs}}<li><a href="{{.}}" target="_blank" rel="noreferrer">{{.}}</a></li>
                  {{end}}
                </ul>
              </div>
              {{end}}
              <div class="candidate-meta">
                <span>provider: {{.Provider}}</span>
                <span>type: {{.CandidateType}}</span>
                <span>domain: {{.Domain}}</span>
                {{if .Confidence}}<span>confidence: {{.Confidence}}</span>{{end}}
              </div>
            </div>
          </div>
        </li>
        {{end}}
      </ol>
    </section>
    {{end}}
    {{end}}
  </main>
  <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">&#9790;</button>
  <script>
    (() => {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else if (saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
      const btn = document.querySelector('.theme-toggle');
      if (btn) {
        btn.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });
      }
    })();
  </script>
</body>
</html>
