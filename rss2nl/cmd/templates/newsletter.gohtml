<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 24px; color: #111; }
    h1 { font-size: 22px; margin-bottom: 20px; }
    h2 { font-size: 18px; margin-top: 24px; }
    ul { padding-left: 18px; }
    li { margin: 6px 0; }
    table { border-collapse: collapse; width: 100%; margin-top: 12px; }
    th, td { border: 1px solid #ddd; padding: 8px; font-size: 13px; vertical-align: top; }
    th { background: #f6f6f6; text-align: left; }
    .muted { color: #666; font-size: 12px; }
    .section { margin-top: 20px; }
    .feeds-hunt { background: #f8fafc; border: 1px solid #ddd; padding: 10px 12px; }
    .item-extra-link { font-size: 12px; color: #0f62fe; text-decoration: none; margin-left: 8px; }
    .item-extra-link:hover { text-decoration: underline; }
    .failure-status { color: #666; font-size: 12px; }
    .failure-suppressed { color: #666; }
    .failure-escalated { color: #9f1239; font-weight: 600; }
    .failure-examples { margin: 4px 0 0; padding-left: 16px; }
  </style>
</head>
<body>
  <h1>{{.Title}}</h1>

  {{if .SourceHuntURL}}
  <p class="section feeds-hunt"><a href="{{.SourceHuntURL}}" target="_blank" rel="noreferrer">Source Discovery: new candidates</a></p>
  {{end}}

  {{if .DashboardConfig.IsShowFetchFailedFeeds}}
  <h2>Fetch Failed Feeds</h2>
  {{if .DashboardData.FailureReport}}
  {{if .DashboardData.FailureReport.TotalFailures}}
  <table>
    <thead><tr><th>Source / Error</th><th>Status</th><th>Examples</th></tr></thead>
    <tbody>
    {{range .DashboardData.FailureReport.Groups}}
    <tr>
      <td>
        <strong>{{.Host}}</strong><br />
        <span class="muted">{{.KindLabel}} · {{.Count}} feed{{if ne .Count 1}}s{{end}}</span>
      </td>
      <td>
        {{if .Escalated}}
        <span class="failure-escalated">{{.Status}}</span>
        {{else if .Suppressed}}
        <span class="failure-suppressed">{{.Status}}</span>
        {{else}}
        <span class="failure-status">{{.Status}}</span>
        {{end}}
      </td>
      <td>
        <ul class="failure-examples">
          {{range .ExampleURLs}}
          <li>{{.}}</li>
          {{end}}
          {{if .RemainingCount}}
          <li class="muted">+{{.RemainingCount}} more</li>
          {{end}}
        </ul>
      </td>
    </tr>
    {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="muted">None</p>
  {{end}}
  {{else}}
  {{if .DashboardData.FailedFeeds}}
  <table>
    <thead><tr><th>Feed</th><th>Error</th></tr></thead>
    <tbody>
    {{range .DashboardData.FailedFeeds}}
    <tr><td>{{.URL}}</td><td>{{if .Err}}{{.Err.Error}}{{else}}{{.Message}}{{end}}</td></tr>
    {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="muted">None</p>
  {{end}}
  {{end}}
  {{end}}

  {{if .DashboardConfig.FeedDetail.Enabled}}
  <h2>Feed Details</h2>
  {{range .DashboardData.FeedDetails}}
  <h3>{{.Type}} <span class="muted">Count: {{len .Feeds}}</span></h3>
  <table>
    <thead><tr><th>Feed</th><th>Last Updated</th><th>Publish Freq</th></tr></thead>
    <tbody>
    {{range .Feeds}}
    <tr><td><a href="{{if .URL}}{{.URL}}{{else}}{{.Feed}}{{end}}" target="_blank" rel="noreferrer">{{if .Des}}{{.Des}}{{else if .URL}}{{.URL}}{{else}}{{.Feed}}{{end}}</a></td><td>{{if .LastUpdated}}{{.LastUpdated}}{{else}}-{{end}}</td><td>{{if .PublishFreq}}{{.PublishFreq}}{{else}}-{{end}}</td></tr>
    {{else}}
    <tr><td><span class="muted">note-only category, no feed urls</span></td><td>-</td><td>-</td></tr>
    {{end}}
    </tbody>
  </table>
  {{end}}
  {{end}}

  {{range .Feeds}}
  <h2>{{.Category}}</h2>
  <ul>
    {{range .Items}}
    <li><a href="{{.Link}}" target="_blank" rel="noreferrer">{{.Title}}</a> {{if .IsMedia}}<span style="display:inline-block;width:8px;height:8px;background-color:#f97316;border-radius:50%;vertical-align:middle;margin-right:4px;"></span>{{end}} {{if .TrnsURL}} <a class="item-extra-link" href="{{.TrnsURL}}" target="_blank" rel="noreferrer">trns</a>{{end}} <span class="muted">{{.PubDate}}</span></li>
    {{else}}
    <li class="muted">No items</li>
    {{end}}
  </ul>
  {{end}}
</body>
</html>
