<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>🌅 Linear 今日任务 · {{.Date}} {{.DayOfWeek}}</title>
  <style>
    :root {
      --bg: #13171f;
      --card-bg: #1a1f28;
      --text: #c2c7d0;
      --heading: #e0e0e0;
      --link: #6db3f2;
      --border: #202632;
      --accent: #01aaff;
      --muted: #8b949e;
      --grp-fixme: #f85149;
      --grp-maybe: #d29922;
      --grp-remove: #8b949e;
      --grp-uncategorized: var(--muted);
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f5f5f5;
        --card-bg: #ffffff;
        --text: #333333;
        --heading: #111111;
        --link: #1a73e8;
        --border: #e0e0e0;
        --accent: #0172ad;
        --muted: #888888;
        --grp-fixme: #cf222e;
        --grp-maybe: #bf8700;
        --grp-remove: #656d76;
        --grp-uncategorized: var(--muted);
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 15px;
      line-height: 1.5;
      padding: 24px 16px;
    }
    .container {
      max-width: 73ch;
      margin: 0 auto;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 32px;
    }
    h1 {
      font-size: 21px;
      font-weight: 700;
      color: var(--heading);
      text-align: center;
      margin-bottom: 4px;
    }
    .date-subtitle {
      text-align: center;
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 28px;
    }

    /* Group headings (Option C: color + count badge) */
    .group-section {
      margin-bottom: 28px;
    }
    .group-heading {
      font-size: 19px;
      font-weight: 700;
      margin: 0 0 4px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .group-heading-fixme { color: var(--grp-fixme); }
    .group-heading-maybe { color: var(--grp-maybe); }
    .group-heading-remove { color: var(--grp-remove); }
    .group-heading-uncategorized { color: var(--grp-uncategorized); }

    .count-badge {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      padding: 1px 10px;
      border-radius: 10px;
      background: var(--border);
      color: var(--muted);
      line-height: 1.6;
      vertical-align: middle;
    }

    /* Per-issue sections */
    .issue-section {
      padding: 8px 0 4px;
    }
    .issue-heading {
      font-size: 17px;
      font-weight: 600;
      margin: 0 0 6px;
    }
    .issue-heading a {
      color: var(--link);
      text-decoration: none;
    }
    .issue-heading a:hover { text-decoration: underline; }

    .issue-content {
      font-size: 14px;
      padding-left: 4px;
    }
    .issue-content h3 {
      color: var(--heading);
      margin: 10px 0 4px;
      font-size: 14px;
      font-weight: 600;
    }
    .issue-content ul { margin: 4px 0 6px; padding-left: 18px; }
    .issue-content li { margin: 2px 0; }
    .issue-content p { margin: 3px 0; }
    .issue-content strong { color: var(--heading); }
    .issue-content code {
      font-size: 13px;
      background: color-mix(in srgb, var(--text) 10%, transparent);
      padding: 1px 4px;
      border-radius: 3px;
    }

    /* Priority tags */
    .tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      padding: 2px 6px;
      border-radius: 4px;
    }
    .tag-p0 { color: var(--grp-fixme); background: color-mix(in srgb, var(--grp-fixme) 15%, transparent); }
    .tag-p1 { color: var(--grp-maybe); background: color-mix(in srgb, var(--grp-maybe) 15%, transparent); }
    .tag-p2 { color: var(--accent); background: color-mix(in srgb, var(--accent) 15%, transparent); }
    .tag-p3 { color: var(--grp-remove); background: color-mix(in srgb, var(--grp-remove) 15%, transparent); }

    .section-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 4px 0;
    }

    /* Separator between groups */
    .group-separator {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0 0 24px;
    }

    /* Compact mode */
    @media (max-width: 600px) {
      .card { padding: 16px; }
      body { padding: 12px 8px; font-size: 13.5px; line-height: 1.4; }
      h1 { font-size: 18px; }
      .date-subtitle { font-size: 12px; margin-bottom: 20px; }
      .group-heading { font-size: 17px; }
      .issue-heading { font-size: 15px; }
      .issue-content { font-size: 13px; }
      .issue-content h3 { font-size: 13px; }
      .count-badge { font-size: 11px; padding: 1px 8px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>🌅 Linear 今日任务</h1>
      <p class="date-subtitle">{{.Date}} {{.DayOfWeek}}</p>

      {{if gt (len .Groups) 0}}
        {{range $gi, $group := .Groups}}
          {{if $gi}}<hr class="group-separator">{{end}}
          <div class="group-section">
            <h2 class="group-heading group-heading-{{$group.Name | groupCSSClass}}">
              {{$group.Emoji}} {{$group.Name}}
              <span class="count-badge">{{$group.GroupCount}} 项</span>
            </h2>

            {{range $group.Issues}}
            <div class="issue-section">
              <h2 class="issue-heading">
                {{if .URL}}<a href="{{.URL}}" target="_blank" rel="noopener">{{.Identifier}} {{.Title}} 🔗</a>{{else}}{{.Identifier}} {{.Title}}{{end}}
                {{if .Priority}}<span class="tag tag-{{.Priority | priorityClass}}">{{.Priority}}</span>{{end}}
              </h2>
              {{if .Content}}
              <div class="issue-content">{{.Content}}</div>
              {{end}}
            </div>
            {{end}}
          </div>
        {{end}}
      {{else}}
        <p class="section-empty">暂无待办任务</p>
      {{end}}
    </div>
  </div>
</body>
</html>
