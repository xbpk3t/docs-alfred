<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>🌅 Linear 今日任务 · {{.Date}} {{.DayOfWeek}}</title>
  <style>
    :root {
      --bg: #13171f;
      --card-bg: #1a1f28;
      --text: #c2c7d0;
      --heading: #e0e0e0;
      --link: #6db3f2;
      --border: #202632;
      --accent: #01aaff;
      --muted: #8b949e;
      --ai-bg: #1a1f28;
      --ai-border: #202632;
      --tag-p0: #f85149;
      --tag-p1: #d29922;
      --tag-p2: #58a6ff;
      --tag-p3: #8b949e;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f5f5f5;
        --card-bg: #ffffff;
        --text: #333333;
        --heading: #111111;
        --link: #1a73e8;
        --border: #e0e0e0;
        --accent: #0172ad;
        --muted: #888888;
        --ai-bg: #ffffff;
        --ai-border: #e0e0e0;
        --tag-p0: #cf222e;
        --tag-p1: #bf8700;
        --tag-p2: #0969da;
        --tag-p3: #656d76;
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 15px;
      line-height: 1.5;
      padding: 24px 16px;
    }
    .container {
      max-width: 73ch;
      margin: 0 auto;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 32px;
    }
    h1 {
      font-size: 21px;
      font-weight: 700;
      color: var(--heading);
      text-align: center;
      margin-bottom: 4px;
    }
    .date-subtitle {
      text-align: center;
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 28px;
    }

    /* Stats bar */
    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 24px;
      font-size: 14px;
    }
    .stat-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .stat-value {
      font-weight: 700;
      color: var(--heading);
      font-size: 16px;
    }

    /* AI Summary */
    .ai-box {
      background: var(--ai-bg);
      border: 1px solid var(--ai-border);
      border-radius: 8px;
      padding: 16px 20px;
      margin-bottom: 24px;
      font-size: 14px;
      line-height: 1.7;
    }
    .ai-box h3 { color: var(--heading); margin: 12px 0 6px; font-size: 15px; }
    .ai-box h4 { color: var(--heading); margin: 8px 0 4px; font-size: 14px; }
    .ai-box ul { margin: 4px 0 8px; padding-left: 20px; }
    .ai-box li { margin: 3px 0; }
    .ai-box p { margin: 6px 0; }
    .ai-box hr { border: none; border-top: 1px solid var(--border); margin: 12px 0; }
    .ai-box strong { color: var(--heading); }

    /* Mini summary tables */
    .summary-section {
      margin-bottom: 20px;
    }
    .summary-heading {
      font-size: 15px;
      font-weight: 600;
      color: var(--heading);
      margin-bottom: 8px;
    }
    table {
      border-collapse: collapse;
      width: 100%;
      font-size: 13px;
    }
    thead th {
      padding: 6px 10px;
      border: 1px solid var(--border);
      text-align: left;
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--muted);
      background: var(--card-bg);
    }
    tbody td {
      padding: 6px 10px;
      border: 1px solid var(--border);
      vertical-align: middle;
    }
    .link {
      color: var(--link);
      text-decoration: none;
      font-weight: 500;
    }
    .link:hover { text-decoration: underline; }

    /* Priority tags */
    .tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      padding: 2px 6px;
      border-radius: 4px;
    }
    .tag-p0 { color: var(--tag-p0); background: color-mix(in srgb, var(--tag-p0) 15%, transparent); }
    .tag-p1 { color: var(--tag-p1); background: color-mix(in srgb, var(--tag-p1) 15%, transparent); }
    .tag-p2 { color: var(--tag-p2); background: color-mix(in srgb, var(--tag-p2) 15%, transparent); }
    .tag-p3 { color: var(--tag-p3); background: color-mix(in srgb, var(--tag-p3) 15%, transparent); }

    .section-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 4px 0;
    }

    /* Compact mode */
    @media (max-width: 600px) {
      .card { padding: 16px; }
      body { padding: 12px 8px; font-size: 13.5px; line-height: 1.4; }
      h1 { font-size: 18px; }
      .date-subtitle { font-size: 12px; margin-bottom: 20px; }
      .stats-bar { font-size: 12px; gap: 16px; }
      .stat-value { font-size: 14px; }
      thead th, tbody td { padding: 4px 6px; font-size: 12px; }
      table { font-size: 12px; }
      .summary-heading { font-size: 14px; }
      .ai-box { font-size: 13px; padding: 12px 14px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>🌅 Linear 今日任务</h1>
      <p class="date-subtitle">{{.Date}} {{.DayOfWeek}}</p>

      <!-- Stats bar -->
      <div class="stats-bar">
        <span class="stat-item">▶️ 进行中 <span class="stat-value">{{.Stats.InProgress}}</span></span>
        <span class="stat-item">📋 待办 <span class="stat-value">{{.Stats.Todo}}</span></span>
        <span class="stat-item">⏰ 今日截止 <span class="stat-value">{{.Stats.DueToday}}</span></span>
      </div>

      {{if .AISummary}}
      <div class="ai-box">
        {{.AISummary | markdownToHTML}}
      </div>
      {{end}}

      <!-- Mini summary table: In Progress -->
      <div class="summary-section">
        <div class="summary-heading">▶️ 进行中 · {{len .InProgress}}</div>
        {{if gt (len .InProgress) 0}}
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Priority</th>
              <th>Team</th>
              <th>Due</th>
            </tr>
          </thead>
          <tbody>
          {{range .InProgress}}
            <tr>
              <td><a href="{{.URL}}" class="link" target="_blank" rel="noopener">{{.Identifier}}</a></td>
              <td>{{.Title}}</td>
              <td>{{if .Priority}}<span class="tag tag-{{priorityClass .Priority}}">{{.Priority}}</span>{{end}}</td>
              <td>{{.TeamName}}</td>
              <td>{{if .DueDate}}{{.DueDate}}{{else}}<span class="section-empty">—</span>{{end}}</td>
            </tr>
          {{end}}
          </tbody>
        </table>
        {{else}}
        <p class="section-empty">暂无进行中的任务</p>
        {{end}}
      </div>

      <!-- Mini summary table: Todo -->
      <div class="summary-section">
        <div class="summary-heading">📋 待办 · {{len .Todo}}</div>
        {{if gt (len .Todo) 0}}
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Priority</th>
              <th>Team</th>
              <th>Due</th>
            </tr>
          </thead>
          <tbody>
          {{range .Todo}}
            <tr>
              <td><a href="{{.URL}}" class="link" target="_blank" rel="noopener">{{.Identifier}}</a></td>
              <td>{{.Title}}</td>
              <td>{{if .Priority}}<span class="tag tag-{{priorityClass .Priority}}">{{.Priority}}</span>{{end}}</td>
              <td>{{.TeamName}}</td>
              <td>{{if .DueDate}}{{.DueDate}}{{else}}<span class="section-empty">—</span>{{end}}</td>
            </tr>
          {{end}}
          </tbody>
        </table>
        {{else}}
        <p class="section-empty">暂无待办任务</p>
        {{end}}
      </div>
    </div>
  </div>
</body>
</html>
