<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>🌙 Linear 今日收获 · {{.Date}} {{.DayOfWeek}}</title>
  <style>
    :root {
      --bg: #13171f;
      --card-bg: #1a1f28;
      --text: #c2c7d0;
      --heading: #e0e0e0;
      --link: #6db3f2;
      --border: #202632;
      --accent: #01aaff;
      --muted: #8b949e;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f5f5f5;
        --card-bg: #ffffff;
        --text: #333333;
        --heading: #111111;
        --link: #1a73e8;
        --border: #e0e0e0;
        --accent: #0172ad;
        --muted: #888888;
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 15px;
      line-height: 1.5;
      padding: 24px 16px;
    }
    .container {
      max-width: 73ch;
      margin: 0 auto;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 32px;
    }
    h1 {
      font-size: 21px;
      font-weight: 700;
      color: var(--heading);
      text-align: center;
      margin-bottom: 4px;
    }
    .date-subtitle {
      text-align: center;
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 28px;
    }

    /* Mini summary tables */
    .summary-section {
      margin-bottom: 20px;
    }
    .summary-heading {
      font-size: 15px;
      font-weight: 600;
      color: var(--heading);
      margin-bottom: 8px;
    }
    table {
      border-collapse: collapse;
      width: 100%;
      font-size: 13px;
    }
    thead th {
      padding: 6px 10px;
      border: 1px solid var(--border);
      text-align: left;
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--muted);
      background: var(--card-bg);
    }
    tbody td {
      padding: 6px 10px;
      border: 1px solid var(--border);
      vertical-align: middle;
    }
    .link {
      color: var(--link);
      text-decoration: none;
      font-weight: 500;
    }
    .link:hover { text-decoration: underline; }

    /* State change badges */
    .state-change {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
    }
    .state-badge {
      display: inline-block;
      padding: 1px 6px;
      border-radius: 3px;
      font-size: 11px;
      font-weight: 600;
    }
    .state-from {
      background: color-mix(in srgb, #f85149 15%, transparent);
      color: #f85149;
    }
    .state-to {
      background: color-mix(in srgb, #3fb950 15%, transparent);
      color: #3fb950;
    }
    .state-arrow {
      color: var(--muted);
    }

    /* Per-issue sections */
    .issue-section {
      padding: 4px 0;
    }
    .issue-heading {
      font-size: 17px;
      font-weight: 600;
      margin: 0 0 4px;
    }
    .issue-heading a {
      color: var(--link);
      text-decoration: none;
    }
    .issue-heading a:hover { text-decoration: underline; }

    .issue-content {
      margin-top: 4px;
      font-size: 14px;
    }
    .issue-content h3 { color: var(--heading); margin: 12px 0 4px; font-size: 15px; }
    .issue-content h4 { color: var(--heading); margin: 8px 0 3px; font-size: 13px; }
    .issue-content ul { margin: 4px 0 8px; padding-left: 18px; }
    .issue-content li { margin: 2px 0; }
    .issue-content p { margin: 4px 0; }
    .issue-content hr { border: none; border-top: 1px solid var(--border); margin: 8px 0; }
    .issue-content strong { color: var(--heading); }

    .separator {
      border: none;
      border-top: 1px solid var(--border);
      margin: 16px 0;
    }

    .section-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 4px 0;
    }

    /* Compact mode */
    @media (max-width: 600px) {
      .card { padding: 16px; }
      body { padding: 12px 8px; font-size: 13.5px; line-height: 1.4; }
      h1 { font-size: 18px; }
      .date-subtitle { font-size: 12px; margin-bottom: 20px; }
      thead th, tbody td { padding: 4px 6px; font-size: 12px; }
      .summary-heading { font-size: 14px; }
      table { font-size: 12px; }
      .issue-heading { font-size: 15px; }
      .issue-content { font-size: 13px; }
      .issue-content h3 { font-size: 13px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>🌙 Linear 今日收获</h1>
      <p class="date-subtitle">{{.Date}} {{.DayOfWeek}}</p>

      {{if or (gt (len .Completed) 0) (gt (len .StateChanges) 0)}}
      <!-- Mini summary table: Completed -->
      {{if gt (len .Completed) 0}}
      <div class="summary-section">
        <div class="summary-heading">✅ 完成 · {{len .Completed}}</div>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Team</th>
            </tr>
          </thead>
          <tbody>
          {{range .Completed}}
            <tr>
              <td><a href="{{.URL}}" class="link" target="_blank" rel="noopener">{{.Identifier}}</a></td>
              <td>{{.Title}}</td>
              <td>{{.TeamName}}</td>
            </tr>
          {{end}}
          </tbody>
        </table>
      </div>
      {{end}}

      <!-- Mini summary table: State Changes -->
      {{if gt (len .StateChanges) 0}}
      <div class="summary-section">
        <div class="summary-heading">🔄 状态变更 · {{len .StateChanges}}</div>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>From → To</th>
              <th>Team</th>
            </tr>
          </thead>
          <tbody>
          {{range .StateChanges}}
            <tr>
              <td><a href="{{.URL}}" class="link" target="_blank" rel="noopener">{{.IssueIdentifier}}</a></td>
              <td>{{.IssueTitle}}</td>
              <td>
                <div class="state-change">
                  <span class="state-badge state-from">{{.FromState}}</span>
                  <span class="state-arrow">→</span>
                  <span class="state-badge state-to">{{.ToState}}</span>
                </div>
              </td>
              <td>{{.TeamName}}</td>
            </tr>
          {{end}}
          </tbody>
        </table>
      </div>
      {{end}}

      <!-- Per-issue sections (only shown when AI review exists) -->
      {{range .Completed}}
      {{if .Review}}<hr class="separator">
      <div class="issue-section">
        <h2 class="issue-heading"><a href="{{.URL}}" target="_blank" rel="noopener">{{.Identifier}} {{.Title}} 🔗</a></h2>
        <div class="issue-content">{{.Review}}</div>
      </div>
      {{end}}
      {{end}}

      {{range .StateChanges}}
      {{if .Review}}<hr class="separator">
      <div class="issue-section">
        <h2 class="issue-heading"><a href="{{.URL}}" target="_blank" rel="noopener">{{.IssueIdentifier}} {{.IssueTitle}} 🔗</a></h2>
        <div class="issue-content">{{.Review}}</div>
      </div>
      {{end}}
      {{end}}
      {{else}}
      <p class="section-empty">今日暂无完成记录</p>
      {{end}}
    </div>
  </div>
</body>
</html>
