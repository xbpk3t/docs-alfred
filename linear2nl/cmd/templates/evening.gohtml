<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>🌙 Linear 今日收获 · {{.Date}} {{.DayOfWeek}}</title>
  <style>
    :root {
      --bg: {{if eq .Theme "dark"}}#1a1a2e{{else}}#ffffff{{end}};
      --text: {{if eq .Theme "dark"}}#e0e0e0{{else}}#111111{{end}};
      --border: {{if eq .Theme "dark"}}#2d2d44{{else}}#e0e0e0{{end}};
      --th-bg: {{if eq .Theme "dark"}}#252540{{else}}#f6f6f6{{end}};
      --muted: {{if eq .Theme "dark"}}#8888aa{{else}}#888888{{end}};
      --review-bg: {{if eq .Theme "dark"}}#1a2a2a{{else}}#f6fff0{{end}};
      --review-border: {{if eq .Theme "dark"}}#2a4a4a{{else}}#cce5cc{{end}};
      --stats-bg: {{if eq .Theme "dark"}}#252540{{else}}#f9f9f9{{end}};
      --link: {{if eq .Theme "dark"}}#6db3f2{{else}}#1a73e8{{end}};
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 24px; color: var(--text); background: var(--bg); }
    h1 { font-size: 22px; margin-bottom: 16px; }
    h2 { font-size: 18px; margin-top: 24px; padding-bottom: 6px; border-bottom: 2px solid var(--border); }
    table { border-collapse: collapse; width: 100%; margin-top: 8px; }
    th, td { border: 1px solid var(--border); padding: 8px 10px; font-size: 13px; text-align: left; }
    th { background: var(--th-bg); font-weight: 600; white-space: nowrap; }
    .muted { color: var(--muted); font-size: 12px; }
    .review { background: var(--review-bg); border: 1px solid var(--review-border); padding: 10px 14px; margin-top: 8px; border-radius: 6px; font-size: 13px; line-height: 1.6; }
    .review h3 { margin: 10px 0 4px; font-size: 14px; }
    .review h4 { margin: 8px 0 3px; font-size: 13px; }
    .review ul { margin: 4px 0 8px; padding-left: 18px; }
    .review li { margin: 2px 0; }
    .review p { margin: 4px 0; }
    .review hr { border: none; border-top: 1px solid var(--review-border); margin: 8px 0; }
    .stats { background: var(--stats-bg); border: 1px solid var(--border); padding: 12px 16px; margin-top: 20px; border-radius: 8px; font-size: 14px; }
    .link { color: var(--link); text-decoration: none; }
    .link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <h1>🌙 Linear 今日收获 · {{.Date}} {{.DayOfWeek}}</h1>

  <h2>✅ 今日完成（{{len .Completed}} 个）</h2>
  {{if gt (len .Completed) 0}}
  <table>
    <thead><tr><th>任务</th><th>团队</th></tr></thead>
    <tbody>
    {{range .Completed}}
    <tr>
      <td><a href="{{.URL}}" class="link" target="_blank">{{.Identifier}}</a> {{.Title}}</td>
      <td>{{.TeamName}}</td>
    </tr>
    {{if .Review}}
    <tr>
      <td colspan="2"><div class="review">{{.Review}}</div></td>
    </tr>
    {{end}}
    {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="muted">今日暂无完成记录</p>
  {{end}}

  <h2>🔄 状态变更（{{len .StateChanges}} 个）</h2>
  {{if gt (len .StateChanges) 0}}
  <table>
    <thead><tr><th>任务</th><th>状态变化</th><th>团队</th></tr></thead>
    <tbody>
    {{range .StateChanges}}
    <tr>
      <td><a href="{{.URL}}" class="link" target="_blank">{{.IssueIdentifier}}</a> {{.IssueTitle}}</td>
      <td>{{.FromState}} → {{.ToState}}</td>
      <td>{{.TeamName}}</td>
    </tr>
    {{if .Review}}
    <tr>
      <td colspan="3"><div class="review">{{.Review}}</div></td>
    </tr>
    {{end}}
    {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="muted">今日暂无状态变更</p>
  {{end}}

  <div class="stats">
    📊 今日完成 {{.Stats.Completed}} · 进行中 {{.Stats.InProgress}}
  </div>
</body>
</html>
